10 REM N4CWENTERM - Net4CPC Terminal
20 REM Reads N4C.CFG and passes config to binary via fixed RAM addresses
30 MODE 2
40 PRINT "Loading N4C-EWEN Terminal..."
50 PRINT
60 MEMORY &6800-1
70 LOAD "charset.bin",&6800
80 GOSUB 9000
90 LOAD "N4CEWEN.BIN",&7000
100 CALL &7000
110 MODE 2:BORDER 0:INK 0,0:INK 1,26
120 PRINT "Ewen-Term Communications program, v3.0 N4C installed."
130 PRINT
140 PRINT "Type |TERM to start terminal mode"
150 PRINT
160 END
9000 OPENIN "N4C.CFG"
9010 ba=&3F10:GOSUB 9100
9020 ba=&3F14:GOSUB 9100
9030 ba=&3F18:GOSUB 9100
9040 ba=&3F1C:GOSUB 9100
9050 CLOSEIN:RETURN
9100 INPUT #9,a$:IF a$="" THEN 9100
9110 eq=INSTR(a$,"="):a$=MID$(a$,eq+1)
9120 p=1:FOR oc=0 TO 3
9130 q=INSTR(p,a$,"."):IF q=0 THEN q=LEN(a$)+1
9140 POKE ba+oc,VAL(MID$(a$,p,q-p)):p=q+1
9150 NEXT oc:RETURN
